# GRVT API — Trading account
# Get these from your GRVT account UI: https://grvt.io
# The API SECRET is your EIP-712 signing private key. Treat it as a wallet key.
GRVT_API_KEY=
GRVT_API_SECRET=0x...
GRVT_TRADING_ACCOUNT_ID=
GRVT_TRADING_ADDRESS=0x...

# Optional: separate funding account (not required for trading)
GRVT_FUNDING_API_KEY=
GRVT_FUNDING_API_SECRET=
GRVT_FUNDING_WALLET_ADDRESS=

# Dashboard / API
DASHBOARD_PORT=3848
DASHBOARD_API_KEY=replace-with-32-char-random-string

# Logging
LOG_LEVEL=info
NODE_ENV=development

# Mock mode (development without touching real GRVT account)
# When MOCK_MODE=true, the bot serves fake data and never authenticates with GRVT
MOCK_MODE=false

# Dry run (real auth, simulated orders) — useful for smoke-testing in production
DRY_RUN=false
